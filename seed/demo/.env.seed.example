# Postgres target. Override if running outside docker-compose.infra.
TARGET_PG_DSN=postgresql://policy7:policy7secret@localhost:5432/policy7?sslmode=disable

# Tenant — MUST match auth7 SEED_ORG_ID and SEED_ORG_CODE.
SEED_ORG_CODE=BJBS
SEED_ORG_ID=00000000-0000-0000-0000-000000000001

# created_by for seeded rows (defaults to deterministic_uuid('user','SYSTEM'))
SEED_CREATED_BY=
